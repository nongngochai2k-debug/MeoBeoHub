local DangMo = false
local TabHienTai = nil

function ChuyenTab(Tab, NoiDung)
    for _, child in pairs(TabBar:GetChildren()) do
        if child:IsA("TextButton") then
            child.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
            child.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end

    for _, child in pairs(ContentFrame:GetChildren()) do
        if child:IsA("ScrollingFrame") then
            child.Visible = false
        end
    end

    Tab.BackgroundColor3 = Color3.fromRGB(255, 100, 150)
    Tab.TextColor3 = Color3.fromRGB(255, 255, 255)
    NoiDung.Visible = true
    TabHienTai = NoiDung
end

TabTrangChu.MouseButton1Click:Connect(function() ChuyenTab(TabTrangChu, NoiDungTrangChu) end)
TabFarm.MouseButton1Click:Connect(function() ChuyenTab(TabFarm, NoiDungFarm) end)
TabBoss.MouseButton1Click:Connect(function() ChuyenTab(TabBoss, NoiDungBoss) end)
TabDiChuyen.MouseButton1Click:Connect(function() ChuyenTab(TabDiChuyen, NoiDungDiChuyen) end)
TabDaoDacBiet.MouseButton1Click:Connect(function() ChuyenTab(TabDaoDacBiet, NoiDungDaoDacBiet) end)
TabRaid.MouseButton1Click:Connect(function() ChuyenTab(TabRaid, NoiDungRaid) end)
TabCaiDat.MouseButton1Click:Connect(function() ChuyenTab(TabCaiDat, NoiDungCaiDat) end)

ToggleButton.MouseButton1Click:Connect(function()
    DangMo = not DangMo
    
    if DangMo then
        MainFrame.Visible = true
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(MainFrame, 
            TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Size = UDim2.new(0, 650, 0, 450)}
        ):Play()
        
        if not TabHienTai then
            ChuyenTab(TabTrangChu, NoiDungTrangChu)
        end
    else
        TweenService:Create(MainFrame, 
            TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In),
            {Size = UDim2.new(0, 0, 0, 0)}
        ):Play()
        
        task.delay(0.3, function()
            MainFrame.Visible = false
        end)
    end
end)

CloseButton.MouseButton1Click:Connect(function()
    DangMo = false
    TweenService:Create(MainFrame, 
        TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        {Size = UDim2.new(0, 0, 0, 0)}
    ):Play()
    
    task.delay(0.3, function()
        MainFrame.Visible = false
    end)
end)

