function TimDaoBiAn()
    if Workspace:FindFirstChild("MysticIsland") then
        return Workspace.MysticIsland.CFrame
    end
    
    for _, v in pairs(Workspace.Map:GetChildren()) do
        if v.Name == "MysticIsland" then
