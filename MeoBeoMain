-- =============================================
-- ĐỀN CÁO (KITSUNE SHRINE)
-- =============================================

function TimDenCao()
    local ViTriDenCao = {
        CFrame.new(-3574.75, 315.43, -10466.71),
        CFrame.new(-3500.12, 300.25, -10500.34),
        CFrame.new(-3600.43, 320.15, -10400.67),
    }
    
    for _, v in pairs(Workspace.Map:GetDescendants()) do
        if v.Name == "KitsuneShrine" or v.Name == "Kitsune" or v.Name == "Shrine" then
            if v:IsA("Model") or v:IsA("Part") then
                return v.CFrame or v.PrimaryPart.CFrame
            end
        end
    end
    
    if Workspace.Map:FindFirstChild("DragonIsland") then
        for _, v in pairs(Workspace.Map.DragonIsland:GetDescendants()) do
            if string.find(v.Name:lower(), "shrine") or string.find(v.Name:lower(), "kitsune") then
                return v.CFrame
            end
        end
    end
    
    return ViTriDenCao[1]
end

function KiemTraDenCao()
    local args = {
        [1] = "KitsuneIsland"
    }
    local result = ReplicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
    
    if result then
        return true
    end
    
    for _, v in pairs(Workspace.Map:GetDescendants()) do
        if v.Name == "KitsuneShrine" then
            return true
        end
    end
    
    return false
end

