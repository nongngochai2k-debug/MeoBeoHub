    SliderDot.Position = UDim2.new((GiaTriMacDinh - Min) / (Max - Min), 0, 0.5, 0)
    SliderDot.Size = UDim2.new(0, 18, 0, 18)
    SliderDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    SliderDot.BorderSizePixel = 0

    local SliderDotCorner = Instance.new("UICorner")
    SliderDotCorner.CornerRadius = UDim.new(1, 0)
    SliderDotCorner.Parent = SliderDot

    local DangKeo = false

    SliderBar.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            DangKeo = true
        end
    end)

    SliderBar.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            DangKeo = false
        end
    end)

    UserInputService.InputChanged:Connect(function(Input)
        if DangKeo and Input.UserInputType == Enum.UserInputType.MouseMovement then
            local ViTriChuot = Input.Position.X
            local ViTriBar = SliderBar.AbsolutePosition.X
            local KichThuocBar = SliderBar.AbsoluteSize.X
            
            local TyLe = math.clamp((ViTriChuot - ViTriBar) / KichThuocBar, 0, 1)
            local GiaTri = math.floor(Min + (Max - Min) * TyLe)
            
            SliderValue.Text = tostring(GiaTri)
            SliderFill.Size = UDim2.new(TyLe, 0, 1, 0)
            SliderDot.Position = UDim2.new(TyLe, 0, 0.5, 0)
            
            if Callback then
                Callback(GiaTri)
            end
        end
    end)

    return Slider
end

