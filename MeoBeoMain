local KetNoiTanCong
function BatDauTanCongNhanh()
    if KetNoiTanCong then return end
    
    KetNoiTanCong = RunService.RenderStepped:Connect(function()
        if _G.CaiDat.TanCongNhanh then
            pcall(function()
                local VuKhiHienTai = nil
                for _, v in pairs(NhanVat:GetChildren()) do
                    if v:IsA("Tool") then
                        VuKhiHienTai = v
                        break
                    end
                end
                
                if VuKhiHienTai then
                    local AC = require(NguoiChoi.PlayerScripts.CombatFramework)
                    local AC2 = debug.getupvalues(AC)[2]
                    local RigController = debug.getupvalues(AC2.activeController)[4]
                    local RigControllerR = debug.getupvalues(RigController)[1]
                    
                    for i = 1, 1 do
                        local BladehitR = RigControllerR:Attack()
                        if BladehitR then
                            ReplicatedStorage.RigControllerEvent:FireServer("weaponChange", tostring(VuKhiHienTai.Name))
                            ReplicatedStorage.RigControllerEvent:FireServer("hit", BladehitR, i, "")
                        end
                    end
                end
            end)
        end
    end)
end

