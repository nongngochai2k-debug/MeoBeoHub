-- Bay đến vị trí
function BayDen(ViTri, TocDo)
    TocDo = TocDo or 300
    local KhoangCach = (ViTri - HumanoidRootPart.Position).Magnitude
    local ThoiGian = KhoangCach / TocDo
    
    if ThoiGian < 0.1 then ThoiGian = 0.1 end
    
    local Tween = TweenService:Create(
        HumanoidRootPart,
        TweenInfo.new(ThoiGian, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(ViTri)}
    )
    
    Tween:Play()
    return Tween
end

-- Dịch chuyển tức thì
