end

-- Trang bị vũ khí
function TrangBiVuKhi(TenVuKhi)
    local VuKhi = NguoiChoi.Backpack:FindFirstChild(TenVuKhi)
    if VuKhi then
        Humanoid:EquipTool(VuKhi)
        return true
    end
    return false
end

-- Tự động trang bị vũ khí tốt nhất
function TuDongTrangBiVuKhi()
    local LoaiVuKhi = _G.CaiDat.VuKhi
    
    for _, v in pairs(NguoiChoi.Backpack:GetChildren()) do
        if v:IsA("Tool") then
            if LoaiVuKhi == "Melee" and v.ToolTip == "Melee" then
                Humanoid:EquipTool(v)
                return
            elseif LoaiVuKhi == "Sword" and v.ToolTip == "Sword" then
                Humanoid:EquipTool(v)
                return
            elseif LoaiVuKhi == "Gun" and v.ToolTip == "Gun" then
                Humanoid:EquipTool(v)
                return
            elseif LoaiVuKhi == "Fruit" and v.ToolTip == "Blox Fruit" then
                Humanoid:EquipTool(v)
                return
            end
        end
    end
end

-- Lấy quái gần nhất
function LayQuaiGanNhat(KhoangCachToiDa)
    KhoangCachToiDa = KhoangCachToiDa or 5000
    local QuaiGanNhat = nil
    local KhoangCachGanNhat = KhoangCachToiDa
    
    for _, Quai in pairs(Workspace.Enemies:GetChildren()) do
        if Quai:IsA("Model") and Quai:FindFirstChild("Humanoid") and Quai:FindFirstChild("HumanoidRootPart") then
            if Quai.Humanoid.Health > 0 then
                local KhoangCach = (Quai.HumanoidRootPart.Position - HumanoidRootPart.Position).Magnitude
                if KhoangCach < KhoangCachGanNhat then
                    KhoangCachGanNhat = KhoangCach
                    QuaiGanNhat = Quai
                end
            end
        end
    end
    
    return QuaiGanNhat
end

-- Kéo quái lại
function KeoQuai(Quai)
    if not _G.CaiDat.KeoQuai then return end
    
    pcall(function()
        if Quai and Quai:FindFirstChild("HumanoidRootPart") and Quai:FindFirstChild("Humanoid") then
            if Quai.Humanoid.Health > 0 then
                Quai.HumanoidRootPart.CFrame = HumanoidRootPart.CFrame * CFrame.new(0, 0, -10)
                Quai.HumanoidRootPart.CanCollide = false
                Quai.HumanoidRootPart.Size = Vector3.new(60, 60, 60)
                Quai.HumanoidRootPart.Transparency = 1
                
                if Quai.Humanoid:FindFirstChild("Animator") then
                    Quai.Humanoid.Animator:Destroy()
                end
                
                sethiddenproperty(Quai, "NetworkOwner", nil)
            end
        end
    end)
end

